            toast.classList.remove('opacity-0');
            setTimeout(() => {
                toast.classList.add('opacity-0');
            }, 2000);
        }

        // --- 체조놀이 로직 ---
        const mascot = document.getElementById('gym-mascot');
        const gymStatus = document.getElementById('gym-status');
        
        function startGym(type) {
            mascot.classList.remove('bounce-slow', 'mascot-gym');
            if (type === 'jump') {
                mascot.classList.add('bounce-slow');
                gymStatus.innerText = "폴짝폴짝! 하늘 높이 뛰어요!";
            } else if (type === 'wave') {
                mascot.classList.add('mascot-gym');
                gymStatus.innerText = "살랑살랑~ 즐겁게 춤을 춰요!";
            }
        }

        function stopGym() {
            mascot.classList.remove('bounce-slow', 'mascot-gym');
            gymStatus.innerText = "조금 쉬었다가 또 만나요!";
        }

        // --- 퍼즐놀이 로직 ---
        const puzzleBoard = document.getElementById('puzzle-board');
        let pieces = ['🍎', '🍌', '🍇', '🍓', '🍒', '🥝', '🫐', '🍑', '🍍'];
        
        function initPuzzle() {
            puzzleBoard.innerHTML = '';
            pieces.forEach((emoji, index) => {
                const div = document.createElement('div');
                div.className = 'puzzle-piece shadow-md border-2 border-yellow-100 hover:bg-yellow-100';
                div.innerText = emoji;
                div.onclick = () => swapPieces(index);
                puzzleBoard.appendChild(div);
            });
        }

        function shufflePuzzle() {
            pieces.sort(() => Math.random() - 0.5);
            initPuzzle();
            showToast("퍼즐이 뒤섞였어요! 맞춰보세요.");
        }

        function swapPieces(index) {
            // 아주 간단한 스왑 로직 (이웃한 것과 바꿈)
            const nextIdx = (index + 1) % pieces.length;
            [pieces[index], pieces[nextIdx]] = [pieces[nextIdx], pieces[index]];
            initPuzzle();
            
            // 승리 체크 (간단화: 특정 순서가 되면)
            if (pieces[0] === '🍎' && pieces[8] === '🍍') {
                showToast("우와! 퍼즐을 다 맞췄어요! 대단해!");
            }
        }

        // --- 글자놀이 카드 로직 ---
        function flipCard(card) {
            const inner = card.querySelector('.card-inner');
            inner.classList.toggle('is-flipped');
        }

        // 초기화
        window.onload = () => {
            initPuzzle();
        };
    </script>
